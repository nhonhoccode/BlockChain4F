# Request Form Template
msgid "Submit New Administrative Request"
msgstr "Gửi Yêu Cầu Hành Chính Mới"

msgid "Important Information"
msgstr "Thông Tin Quan Trọng"

msgid "Your request will be securely registered on the blockchain, ensuring transparency and integrity of your administrative procedure. You will receive a unique transaction ID for tracking purposes."
msgstr "Yêu cầu của bạn sẽ được đăng ký an toàn trên blockchain, đảm bảo tính minh bạch và toàn vẹn của thủ tục hành chính. Bạn sẽ nhận được một ID giao dịch duy nhất để theo dõi."

msgid "Request Details"
msgstr "Chi Tiết Yêu Cầu"

msgid "Request Category"
msgstr "Loại Danh Mục"

msgid "Select Category"
msgstr "Chọn Danh Mục"

msgid "-- Select a category --"
msgstr "-- Chọn một danh mục --"

msgid "Select the appropriate category for your administrative request."
msgstr "Chọn danh mục phù hợp cho yêu cầu hành chính của bạn."

msgid "-- First select a category --"
msgstr "-- Trước tiên hãy chọn một danh mục --"

msgid "Personal Information"
msgstr "Thông Tin Cá Nhân"

msgid "Full Name"
msgstr "Họ và Tên"

msgid "Phone Number"
msgstr "Số Điện Thoại"

msgid "Address"
msgstr "Địa Chỉ"

msgid "Description"
msgstr "Mô Tả"

msgid "Provide a detailed description of your request. Include any relevant information that might help process your request efficiently."
msgstr "Cung cấp mô tả chi tiết về yêu cầu của bạn. Bao gồm bất kỳ thông tin liên quan nào có thể giúp xử lý yêu cầu của bạn một cách hiệu quả."

msgid "Payment Information"
msgstr "Thông Tin Thanh Toán"

msgid "Payment Amount"
msgstr "Số Tiền Thanh Toán"

msgid "The payment amount will be determined based on your request type. You can leave this as 0 if you're unsure."
msgstr "Số tiền thanh toán sẽ được xác định dựa trên loại yêu cầu của bạn. Bạn có thể để là 0 nếu không chắc chắn."

msgid "Back"
msgstr "Quay Lại"

msgid "Submit Request"
msgstr "Gửi Yêu Cầu"

